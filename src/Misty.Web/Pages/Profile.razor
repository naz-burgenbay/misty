@page "/profile"
@inject IAuthService Auth

<PageTitle>Profile | Misty</PageTitle>

@code {
    private MockUser Me => Auth.CurrentUser ?? MockDataStore.Me;
    private string _displayName = string.Empty;
    private string _username = string.Empty;
    private string _bio = string.Empty;

    protected override void OnInitialized()
    {
        _displayName = Me.DisplayName;
        _username = Me.Username;
        _bio = Me.Bio ?? string.Empty;
    }
}

<div class="page">
    <div class="content">
        <header class="head">
            <h1>Profile</h1>
            <p>This is how others see you on Misty.</p>
        </header>

        <section class="card">
            <div class="avatar-row">
                <Avatar Name="@_displayName" Size="Avatar.AvatarSize.Large" />
                <div class="avatar-actions">
                    <Button Variant="Button.ButtonVariant.Ghost">Change picture</Button>
                    <Button Variant="Button.ButtonVariant.Ghost">Remove</Button>
                </div>
            </div>

            <div class="field">
                <span class="lbl">Display name</span>
                <TextField Value="@_displayName" ValueChanged="@(v => _displayName = v ?? string.Empty)" />
            </div>
            <div class="field">
                <span class="lbl">Username</span>
                <TextField Value="@_username" ValueChanged="@(v => _username = v ?? string.Empty)" />
            </div>
            <div class="field">
                <span class="lbl">Bio</span>
                <TextField Value="@_bio" ValueChanged="@(v => _bio = v ?? string.Empty)" Placeholder="Tell people a little about yourself." />
            </div>

            <div class="actions">
                <Button Variant="Button.ButtonVariant.Ghost">Cancel</Button>
                <Button Variant="Button.ButtonVariant.Primary">Save changes</Button>
            </div>
        </section>

        <section class="card">
            <header class="card-head">
                <h2>Privacy</h2>
                <a href="/profile/blocked">Manage blocked users</a>
            </header>
            <p class="hint">Manage who you've blocked from messaging you.</p>
        </section>
    </div>
</div>
