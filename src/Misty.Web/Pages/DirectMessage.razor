@page "/dm/{ConversationId:guid}"
@implements IDisposable
@inject NavigationManager Nav
@inject IDirectMessageService Conversations
@inject IUserDirectory Users
@inject IMessageStore MessageStore
@inject IToastService Toasts
@inject IModalService Modals

@code {
    [Parameter] public Guid ConversationId { get; set; }

    private DirectConversationDto? _dm;
    private UserSummary? _other;
    private IReadOnlyList<MockMessage> _messages = Array.Empty<MockMessage>();
    private MockMessage? _replyingTo;
    private IDisposable? _messagesSub;
    private IDisposable? _conversationsSub;
    private bool _loadError;
    private bool _loadingOlder;
    private bool _userSubscribed;

    private MockMessage? _editingMessage;

    private bool _infoOpen;

    protected override async Task OnParametersSetAsync()
    {
        _replyingTo = null;
        _loadError = false;

        _messagesSub?.Dispose();
        _conversationsSub?.Dispose();

        if (!_userSubscribed)
        {
            Users.Updated += OnUserUpdated;
            _userSubscribed = true;
        }

        _conversationsSub = Conversations.MyConversations.Subscribe(list =>
        {
            _dm = list.FirstOrDefault(c => c.Id == ConversationId);
            if (_dm is not null)
            {
                _other = Users.Get(_dm.OtherUserId);
                _ = Users.EnsureAsync(_dm.OtherUserId);
            }
            InvokeAsync(StateHasChanged);
        });

        _messagesSub = MessageStore.GetConversation(ConversationId).Subscribe(list =>
        {
            _messages = list;
            InvokeAsync(StateHasChanged);
        });

        if (Conversations.MyConversations.Value.Count == 0)
            await Conversations.RefreshAsync();

        try
        {
            await MessageStore.EnsureConversationLoadedAsync(ConversationId);
        }
        catch
        {
            _loadError = true;
        }
    }

    private string OtherName => _other?.DisplayName ?? "…";

    private async Task SendAsync(MessageComposer.MessageComposerSubmit submit)
    {
        if (string.IsNullOrWhiteSpace(submit.Content) && submit.Attachment is null) return;
        var parentId = _replyingTo?.Id;
        _replyingTo = null;
        try
        {
            var messageId = await MessageStore.SendAsync(ConversationId, submit.Content ?? string.Empty, parentId);
            if (submit.Attachment is { } file && messageId is { } mid)
            {
                using var stream = file.OpenReadStream(25 * 1024 * 1024);
                await MessageStore.UploadAttachmentAsync(ConversationId, mid, file.Name,
                    string.IsNullOrEmpty(file.ContentType) ? "application/octet-stream" : file.ContentType,
                    file.Size, stream);
            }
        }
        catch (Exception ex)
        {
            Toasts.Show($"Send failed: {ex.Message}", ToastKind.Error);
        }
    }

    private async Task LoadOlderAsync()
    {
        if (_loadingOlder) return;
        _loadingOlder = true;
        try
        {
            await MessageStore.LoadOlderAsync(ConversationId);
        }
        catch (Exception ex)
        {
            Toasts.Show($"Couldn't load older messages: {ex.Message}", ToastKind.Error);
        }
        finally
        {
            _loadingOlder = false;
        }
    }

    private async Task EditMessageAsync(MockMessage message)
    {
        _editingMessage = message;
    }

    private async Task SaveEditAsync(string newContent)
    {
        if (_editingMessage is null) return;
        try
        {
            await MessageStore.EditAsync(ConversationId, _editingMessage.Id, newContent);
            _editingMessage = null;
        }
        catch (Exception ex)
        {
            Toasts.Show($"Edit failed: {ex.Message}", ToastKind.Error);
        }
    }

    private async Task DeleteMessageAsync(Guid messageId)
    {
        var ok = await Modals.ConfirmAsync(new ConfirmRequest(
            Title: "Delete message",
            Message: "This message will be permanently deleted. This cannot be undone.",
            ConfirmLabel: "Delete",
            IsDestructive: true));
        if (!ok) return;

        try
        {
            await MessageStore.DeleteAsync(ConversationId, messageId);
            Toasts.Show("Message deleted.", ToastKind.Success);
        }
        catch (Exception ex)
        {
            Toasts.Show($"Delete failed: {ex.Message}", ToastKind.Error);
        }
    }

    public void Dispose()
    {
        _messagesSub?.Dispose();
        _conversationsSub?.Dispose();
        if (_userSubscribed) Users.Updated -= OnUserUpdated;
    }

    private void OnUserUpdated(Guid userId)
    {
        if (_dm is null || userId != _dm.OtherUserId) return;
        _other = Users.Get(userId);
        InvokeAsync(StateHasChanged);
    }
}

@if (_loadError)
{
    <div class="missing">Couldn't load this conversation.</div>
}
else
{
    <div class="page">
        <div class="main">
            <ConversationHeader Title="@OtherName"
                                ShowChannelActions="false"
                                OnOpenDmInfo="@(() => _infoOpen = !_infoOpen)">
                <TitleIcon>
                    <UserContextMenu UserId="@(_dm?.OtherUserId ?? Guid.Empty)"
                                     UserName="@OtherName"
                                     UserUsername="@(_other?.Username)">
                        <Avatar Name="@OtherName"
                                Size="Avatar.AvatarSize.Small" />
                    </UserContextMenu>
                </TitleIcon>
            </ConversationHeader>

            <MessageStream Messages="_messages"
                           HasMoreOlder="@MessageStore.HasMoreOlder(ConversationId)"
                           LoadingOlder="_loadingOlder"
                           OnLoadOlder="LoadOlderAsync"
                           OnReply="@(EventCallback.Factory.Create<MockMessage>(this, m => _replyingTo = m))"
                           OnEditMessage="@(EventCallback.Factory.Create<MockMessage>(this, EditMessageAsync))"
                           OnDeleteMessage="@(EventCallback.Factory.Create<Guid>(this, DeleteMessageAsync))" />

            <MessageComposer Placeholder="@($"Message {OtherName}")"
                             ReplyingTo="_replyingTo"
                             AttachmentsEnabled="true"
                             OnClearReply="@(() => _replyingTo = null)"
                             OnSend="SendAsync" />
        </div>

        @if (_infoOpen && _dm is not null)
        {
            <DmInfoPanel ConversationId="@ConversationId"
                         OtherUserId="@_dm.OtherUserId"
                         OnClose="@(() => _infoOpen = false)" />
        }
    </div>

    <EditMessageModal Open="@(_editingMessage is not null)"
                      InitialContent="@(_editingMessage?.Content ?? string.Empty)"
                      OnClose="@(() => _editingMessage = null)"
                      OnSave="SaveEditAsync" />
}
