@page "/c/{ChannelId:guid}"
@inject NavigationManager Nav

@code {
    [Parameter] public Guid ChannelId { get; set; }

    private MockChannel? _channel;
    private IReadOnlyList<MockMessage> _messages = Array.Empty<MockMessage>();
    private MockMessage? _replyingTo;

    private bool _membersOpen;
    private bool _settingsOpen;
    private bool _moderationOpen;

    private MockMembership? _moderationTarget;
    private string _moderationAction = "Mute";
    private string _moderationHours = "24";
    private string _moderationReason = string.Empty;

    protected override void OnParametersSet()
    {
        _channel = MockDataStore.GetChannel(ChannelId);
        _messages = MockDataStore.GetMessages(ChannelId);
        _replyingTo = null;
    }

    private string Subtitle => _channel is null ? string.Empty :
        $"{_channel.MemberCount} members";

    private void OpenModeration(MockMembership m)
    {
        _moderationTarget = m;
        _moderationAction = "Mute";
        _moderationHours = "24";
        _moderationReason = string.Empty;
        _moderationOpen = true;
    }
}

@if (_channel is null)
{
    <div class="missing">Channel not found.</div>
}
else
{
    <div class="page">
        <div class="main">
            <ConversationHeader Title="@_channel.Name"
                                Subtitle="@Subtitle"
                                ShowAiBadge="@_channel.IsAiAssistantEnabled"
                                OnToggleMembers="@(() => _membersOpen = !_membersOpen)"
                                OnOpenSettings="@(() => _settingsOpen = true)">
                <TitleIcon>
                    <Blazicon Svg="@(_channel.IsPrivate ? Lucide.Lock : Lucide.Hash)" />
                </TitleIcon>
            </ConversationHeader>

            <MessageStream Messages="_messages" />

            <MessageComposer Placeholder="@($"Message #{_channel.Name}")"
                             ReplyingTo="_replyingTo"
                             OnClearReply="@(() => _replyingTo = null)"
                             OnSend="@(_ => Task.CompletedTask)" />
        </div>

        @if (_membersOpen)
        {
            <aside class="members-pane">
                <div class="pane-head">
                    <h3>Members</h3>
                    <IconButton Title="Close" OnClick="@(() => _membersOpen = false)">
                        <Blazicon Svg="Lucide.X" />
                    </IconButton>
                </div>
                <div class="pane-body">
                    <MembersPanel Channel="_channel" />
                    <div class="mod-actions">
                        <h4>Moderation demo</h4>
                        <p>Click a member to mute, warn, or ban them.</p>
                        @foreach (var m in _channel.Members)
                        {
                            var user = MockDataStore.GetUser(m.UserId);
                            <Button Variant="Button.ButtonVariant.Ghost" OnClick="@(() => OpenModeration(m))">
                                Moderate @user.DisplayName
                            </Button>
                        }
                    </div>
                </div>
            </aside>
        }
    </div>

    <Drawer Open="_settingsOpen" Title="Channel settings" OnClose="@(() => _settingsOpen = false)">
        <div class="settings">
            <div class="field">
                <span class="lbl">Name</span>
                <TextField Value="@_channel.Name" />
            </div>
            <div class="field">
                <span class="lbl">Privacy</span>
                <SegmentedControl Options="@(new [] { "Public", "Private" })"
                                  Value="@(_channel.IsPrivate ? "Private" : "Public")" />
            </div>
            <div class="field">
                <span class="lbl">AI assistant</span>
                <SegmentedControl Options="@(new [] { "Off", "On" })"
                                  Value="@(_channel.IsAiAssistantEnabled ? "On" : "Off")" />
            </div>
            <div class="field danger-zone">
                <h4>Danger zone</h4>
                <Button Variant="Button.ButtonVariant.Danger">Delete channel</Button>
            </div>
        </div>
    </Drawer>

    @if (_moderationOpen && _moderationTarget is not null)
    {
        var targetUser = MockDataStore.GetUser(_moderationTarget.UserId);
        <Modal Open="true" Title="@($"Moderate {targetUser.DisplayName}")" OnClose="@(() => _moderationOpen = false)">
            <ChildContent>
                <div class="mod-form">
                    @if (_moderationTarget.Moderation != ModerationKind.None)
                    {
                        <div class="existing">
                            <Badge Variant="@(_moderationTarget.Moderation switch {
                                ModerationKind.Muted  => Badge.BadgeVariant.Muted,
                                ModerationKind.Warned => Badge.BadgeVariant.Warned,
                                ModerationKind.Banned => Badge.BadgeVariant.Banned,
                                _ => Badge.BadgeVariant.Muted })"
                                   Label="@_moderationTarget.Moderation.ToString()" />
                            <span>Existing moderation is active.</span>
                        </div>
                    }
                    else
                    {
                        <div class="field">
                            <span class="lbl">Action</span>
                            <SegmentedControl Options="@(new [] { "Mute", "Warn", "Ban" })"
                                              Value="@_moderationAction"
                                              ValueChanged="@(v => _moderationAction = v)" />
                        </div>
                        <div class="field">
                            <span class="lbl">Duration (hours)</span>
                            <TextField Value="@_moderationHours" ValueChanged="@(v => _moderationHours = v ?? string.Empty)" />
                        </div>
                        <div class="field">
                            <span class="lbl">Reason</span>
                            <TextField Value="@_moderationReason" ValueChanged="@(v => _moderationReason = v ?? string.Empty)"
                                       Placeholder="Optional note shown in the audit log" />
                        </div>
                    }
                </div>
            </ChildContent>
            <Footer>
                <Button Variant="Button.ButtonVariant.Ghost" OnClick="@(() => _moderationOpen = false)">Cancel</Button>
                @if (_moderationTarget.Moderation != ModerationKind.None)
                {
                    <Button Variant="Button.ButtonVariant.Primary" OnClick="@(() => _moderationOpen = false)">
                        Revoke moderation
                    </Button>
                }
                else
                {
                    <Button Variant="Button.ButtonVariant.Primary" OnClick="@(() => _moderationOpen = false)">
                        @($"{_moderationAction} {targetUser.DisplayName}")
                    </Button>
                }
            </Footer>
        </Modal>
    }
}
