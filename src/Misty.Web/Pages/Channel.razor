@page "/c/{ChannelId:guid}"
@implements IDisposable
@inject NavigationManager Nav
@inject IChannelService Channels
@inject IMessageStore MessageStore
@inject IPermissionsCache Permissions
@inject IToastService Toasts
@inject IModalService Modals

@code {
    [Parameter] public Guid ChannelId { get; set; }

    private ChannelSummaryDto? _channel;
    private IReadOnlyList<MockMessage> _messages = Array.Empty<MockMessage>();
    private MockMessage? _replyingTo;
    private ChannelPermissionFlags _myPermissions;
    private IDisposable? _messagesSub;
    private IDisposable? _channelsSub;
    private IDisposable? _permissionsSub;
    private bool _loadError;
    private bool _loadingOlder;

    private bool _membersOpen;
    private Guid? _moderationTarget;

    private MockMessage? _editingMessage;

    protected override async Task OnParametersSetAsync()
    {
        _replyingTo = null;
        _loadError = false;

        _messagesSub?.Dispose();
        _channelsSub?.Dispose();
        _permissionsSub?.Dispose();

        _channelsSub = Channels.MyChannels.Subscribe(list =>
        {
            _channel = list.FirstOrDefault(c => c.Id == ChannelId);
            InvokeAsync(StateHasChanged);
        });

        _messagesSub = MessageStore.GetConversation(ChannelId).Subscribe(list =>
        {
            _messages = list;
            InvokeAsync(StateHasChanged);
        });

        _permissionsSub = Permissions.Watch(ChannelId).Subscribe(flags =>
        {
            _myPermissions = flags;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await MessageStore.EnsureLoadedAsync(ChannelId);
        }
        catch
        {
            _loadError = true;
        }
    }

    private string Subtitle => _channel is null ? string.Empty : $"{_channel.MemberCount} members";

    private bool CanSend       => _channel is not null;
    private bool CanModerate   => _myPermissions.CanModerate();
    private bool CanManageChannel => _myPermissions.HasFlag(ChannelPermissionFlags.ManageChannel);

    private void OpenSettings() => Nav.NavigateTo($"/c/{ChannelId}/settings");

    private async Task SendAsync(MessageComposer.MessageComposerSubmit submit)
    {
        if (string.IsNullOrWhiteSpace(submit.Content) && submit.Attachment is null) return;
        var parentId = _replyingTo?.Id;
        _replyingTo = null;
        try
        {
            var messageId = await MessageStore.SendAsync(ChannelId, submit.Content ?? string.Empty, parentId);
            if (submit.Attachment is { } file && messageId is { } mid)
            {
                using var stream = file.OpenReadStream(25 * 1024 * 1024);
                await MessageStore.UploadAttachmentAsync(ChannelId, mid, file.Name,
                    string.IsNullOrEmpty(file.ContentType) ? "application/octet-stream" : file.ContentType,
                    file.Size, stream);
            }
        }
        catch (Exception ex)
        {
            Toasts.Show($"Send failed: {ex.Message}", ToastKind.Error);
        }
    }

    private async Task AddReactionAsync((Guid MessageId, string EmojiCode) t)
    {
        try { await MessageStore.AddReactionAsync(ChannelId, t.MessageId, t.EmojiCode); }
        catch (Exception ex) { Toasts.Show($"Reaction failed: {ex.Message}", ToastKind.Error); }
    }

    private async Task RemoveReactionAsync((Guid MessageId, string EmojiCode) t)
    {
        try { await MessageStore.RemoveReactionAsync(ChannelId, t.MessageId, t.EmojiCode); }
        catch (Exception ex) { Toasts.Show($"Reaction failed: {ex.Message}", ToastKind.Error); }
    }

    private async Task LoadOlderAsync()
    {
        if (_loadingOlder) return;
        _loadingOlder = true;
        try
        {
            await MessageStore.LoadOlderAsync(ChannelId);
        }
        catch (Exception ex)
        {
            Toasts.Show($"Couldn't load older messages: {ex.Message}", ToastKind.Error);
        }
        finally
        {
            _loadingOlder = false;
        }
    }

    private async Task EditMessageAsync(MockMessage message)
    {
        _editingMessage = message;
    }

    private async Task SaveEditAsync(string newContent)
    {
        if (_editingMessage is null) return;
        try
        {
            await MessageStore.EditAsync(ChannelId, _editingMessage.Id, newContent);
            _editingMessage = null;
        }
        catch (Exception ex)
        {
            Toasts.Show($"Edit failed: {ex.Message}", ToastKind.Error);
        }
    }

    private async Task DeleteMessageAsync(Guid messageId)
    {
        var ok = await Modals.ConfirmAsync(new ConfirmRequest(
            Title: "Delete message",
            Message: "This message will be permanently deleted. This cannot be undone.",
            ConfirmLabel: "Delete",
            IsDestructive: true));
        if (!ok) return;

        try
        {
            await MessageStore.DeleteAsync(ChannelId, messageId);
            Toasts.Show("Message deleted.", ToastKind.Success);
        }
        catch (Exception ex)
        {
            Toasts.Show($"Delete failed: {ex.Message}", ToastKind.Error);
        }
    }

    public void Dispose()
    {
        _messagesSub?.Dispose();
        _channelsSub?.Dispose();
        _permissionsSub?.Dispose();
    }
}

@if (_channel is null)
{
    <div class="missing">
        @(_loadError ? "Couldn't load this channel." : "Loading…")
    </div>
}
else
{
    <div class="page">
        <div class="main">
            <ConversationHeader Title="@_channel.Name"
                                Subtitle="@Subtitle"
                                ShowAiBadge="@_channel.IsAiAssistantEnabled"
                                OnToggleMembers="@(() => _membersOpen = !_membersOpen)"
                                OnOpenSettings="OpenSettings">
                <TitleIcon>
                    <Blazicon Svg="@(_channel.IsPrivate ? Lucide.Lock : Lucide.Hash)" />
                </TitleIcon>
            </ConversationHeader>

            <MessageStream Messages="_messages"
                           ChannelId="ChannelId"
                           HasMoreOlder="@MessageStore.HasMoreOlder(ChannelId)"
                           LoadingOlder="_loadingOlder"
                           OnLoadOlder="LoadOlderAsync"
                           OnReply="@(EventCallback.Factory.Create<MockMessage>(this, m => _replyingTo = m))"
                           ReactionsEnabled="true"
                           OnAddReaction="AddReactionAsync"
                           OnRemoveReaction="RemoveReactionAsync"
                           CanModerate="CanModerate"
                           OnModerateUser="@(EventCallback.Factory.Create<Guid>(this, id => _moderationTarget = id))"
                           OnEditMessage="@(EventCallback.Factory.Create<MockMessage>(this, EditMessageAsync))"
                           OnDeleteMessage="@(EventCallback.Factory.Create<Guid>(this, DeleteMessageAsync))" />

            <MessageComposer Placeholder="@($"Message #{_channel.Name}")"
                             ReplyingTo="_replyingTo"
                             Disabled="@(!CanSend)"
                             OnClearReply="@(() => _replyingTo = null)"
                             OnSend="SendAsync" />
        </div>

        @if (_membersOpen)
        {
            <aside class="members-pane">
                <div class="pane-head">
                    <h3>Members</h3>
                    <IconButton Title="Close" OnClick="@(() => _membersOpen = false)">
                        <Blazicon Svg="Lucide.X" />
                    </IconButton>
                </div>
                <div class="pane-body">
                    <MembersPanel ChannelId="@_channel.Id" />
                </div>
            </aside>
        }
    </div>

    <ModerationActionModal Open="@(_moderationTarget is not null)"
                           ChannelId="ChannelId"
                           TargetUserId="_moderationTarget"
                           OnClose="@(() => _moderationTarget = null)" />
    <EditMessageModal Open="@(_editingMessage is not null)"
                      InitialContent="@(_editingMessage?.Content ?? string.Empty)"
                      OnClose="@(() => _editingMessage = null)"
                      OnSave="SaveEditAsync" />
}
