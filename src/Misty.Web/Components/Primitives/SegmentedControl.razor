
@code {
    [Parameter, EditorRequired] public IReadOnlyList<string> Options { get; set; } = Array.Empty<string>();
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private Task SelectAsync(string option) =>
        Disabled || option == Value ? Task.CompletedTask : ValueChanged.InvokeAsync(option);
}

<div class="segmented @(Disabled ? "disabled" : null)" role="tablist">
    @foreach (var option in Options)
    {
        var selected = option == Value;
        <button type="button"
                class="segment @(selected ? "selected" : null)"
                role="tab"
                aria-selected="@selected"
                disabled="@Disabled"
                @onclick="() => SelectAsync(option)">
            @option
        </button>
    }
</div>
