@using Misty.Web.Components.Primitives
@using Misty.Web.Services.Communication
@inject IChannelMembersService MembersService
@inject IChannelRolesService RolesService

@code {
    [Parameter, EditorRequired] public Guid ChannelId { get; set; }

    private IReadOnlyList<ChannelMemberDto> _members = Array.Empty<ChannelMemberDto>();
    private Dictionary<Guid, string> _roleNames = new();
    private bool _loading = true;
    private Guid _loadedFor;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedFor == ChannelId && !_loading)
            return;
        _loadedFor = ChannelId;
        _loading = true;

        var rolesTask = RolesService.GetRolesAsync(ChannelId);
        var membersTask = MembersService.GetMembersAsync(ChannelId);
        await Task.WhenAll(rolesTask, membersTask);

        _roleNames = (await rolesTask).ToDictionary(r => r.Id, r => r.Name);
        _members = await membersTask;
        _loading = false;
    }
}

<div class="panel">
    @if (_loading)
    {
        <p class="empty">Loading members…</p>
    }
    else if (_members.Count == 0)
    {
        <p class="empty">No members yet.</p>
    }
    else
    {
        <section class="group">
            <h3 class="group-title">Members · @_members.Count</h3>
            @foreach (var m in _members)
            {
                <UserContextMenu UserId="@m.UserId"
                                 UserName="@m.DisplayName"
                                 UserUsername="@m.Username"
                                 ChannelId="@ChannelId"
                                 Class="member-anchor">
                    <div class="member">
                        <Avatar Name="@m.DisplayName" Size="Avatar.AvatarSize.Medium" />
                        <div class="info">
                            <div class="line">
                                <span class="name">@m.DisplayName</span>
                                @foreach (var roleId in m.RoleIds)
                                {
                                    if (_roleNames.TryGetValue(roleId, out var roleName))
                                    {
                                        <Badge Variant="Badge.BadgeVariant.Admin" Label="@roleName" />
                                    }
                                }
                                @foreach (var mod in m.ActiveModerationTypes)
                                {
                                    @switch (mod)
                                    {
                                        case ChannelMemberModerationKind.Mute:
                                            <Badge Variant="Badge.BadgeVariant.Muted" Label="Muted" />
                                            break;
                                        case ChannelMemberModerationKind.Ban:
                                            <Badge Variant="Badge.BadgeVariant.Banned" Label="Banned" />
                                            break;
                                        case ChannelMemberModerationKind.Warn:
                                            <Badge Variant="Badge.BadgeVariant.Warned" Label="Warned" />
                                            break;
                                    }
                                }
                            </div>
                            <div class="handle">@m.Username</div>
                        </div>
                    </div>
                </UserContextMenu>
            }
        </section>
    }
</div>
