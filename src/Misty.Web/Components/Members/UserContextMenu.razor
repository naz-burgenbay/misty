@using Misty.Web.Services.Common
@inject IAuthService Auth
@inject IDirectMessageService DirectMessages
@inject IFriendService Friends
@inject IUserBlockService Blocks
@inject IPermissionsCache Permissions
@inject IModerationService Moderation
@inject IToastService Toasts
@inject NavigationManager Nav
@implements IDisposable

@code {
    [Parameter, EditorRequired] public Guid UserId { get; set; }
    [Parameter] public string? UserName { get; set; }
    [Parameter] public string? UserUsername { get; set; }
    [Parameter] public Guid? ChannelId { get; set; }
    [Parameter] public bool IsTargetOwner { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private bool _open;
    private bool _isFriend;
    private ChannelPermissionFlags _flags;
    private IDisposable? _friendsSub;
    private IDisposable? _flagsSub;
    private bool _moderationModalOpen;
    private bool _rolesModalOpen;
    private bool _inviteToChannelOpen;
    private bool _reportModalOpen;
    private ModerationActionType _pendingKind;

    private bool IsSelf => Auth.CurrentUser?.Id == UserId;

    private bool InChannel => ChannelId is not null;
    private bool CanModerate => InChannel && _flags.CanModerate();
    private bool CanMute => InChannel && (_flags & ChannelPermissionFlags.MuteMembers) != 0;
    private bool CanBan => InChannel && (_flags & ChannelPermissionFlags.BanMembers) != 0;
    private bool CanKick => InChannel && (_flags & ChannelPermissionFlags.KickMembers) != 0;
    private bool CanManageRoles => InChannel && (_flags & ChannelPermissionFlags.ManageRoles) != 0;

    protected override void OnInitialized()
    {
        _friendsSub = Friends.MyFriends.Subscribe(_ =>
        {
            _isFriend = Friends.IsFriend(UserId);
            InvokeAsync(StateHasChanged);
        });
        _isFriend = Friends.IsFriend(UserId);
    }

    protected override void OnParametersSet()
    {
        _flagsSub?.Dispose();
        if (ChannelId is { } cid)
        {
            var obs = Permissions.Watch(cid);
            _flags = obs.Value;
            _flagsSub = obs.Subscribe(f =>
            {
                _flags = f;
                InvokeAsync(StateHasChanged);
            });
        }
        else
        {
            _flags = ChannelPermissionFlags.None;
        }
    }

    public void Dispose()
    {
        _friendsSub?.Dispose();
        _flagsSub?.Dispose();
    }

    private void OpenMenu() => _open = true;
    private void CloseMenu() => _open = false;

    private async Task SendDmAsync()
    {
        CloseMenu();
        try
        {
            var dm = await DirectMessages.CreateOrGetAsync(UserId);
            Nav.NavigateTo($"/dm/{dm.Id}");
        }
        catch (Exception ex)
        {
            Toasts.Show(HttpErrors.Friendly(ex), ToastKind.Error);
        }
    }

    private async Task SendFriendRequestAsync()
    {
        CloseMenu();
        if (string.IsNullOrWhiteSpace(UserUsername))
        {
            Toasts.Show("Username unavailable.", ToastKind.Error);
            return;
        }
        try
        {
            await Friends.SendRequestAsync(UserUsername!);
            Toasts.Show($"Friend request sent to {DisplayLabel}.", ToastKind.Success);
        }
        catch (Exception ex)
        {
            Toasts.Show(HttpErrors.Friendly(ex), ToastKind.Error);
        }
    }

    private async Task BlockAsync()
    {
        CloseMenu();
        try
        {
            await Blocks.BlockAsync(UserId);
            Toasts.Show($"{DisplayLabel} blocked.", ToastKind.Success);
        }
        catch (Exception ex)
        {
            Toasts.Show(HttpErrors.Friendly(ex), ToastKind.Error);
        }
    }

    private void Report()
    {
        CloseMenu();
        _reportModalOpen = true;
    }

    private void OpenModeration(ModerationActionType kind)
    {
        CloseMenu();
        _pendingKind = kind;
        _moderationModalOpen = true;
    }

    private async Task KickAsync()
    {
        CloseMenu();
        if (ChannelId is not { } cid) return;
        try
        {
            await Moderation.KickAsync(cid, UserId, "Kicked from channel.");
            Toasts.Show($"{DisplayLabel} kicked.", ToastKind.Success);
        }
        catch (Exception ex)
        {
            Toasts.Show(HttpErrors.Friendly(ex), ToastKind.Error);
        }
    }

    private void OpenManageRoles()
    {
        CloseMenu();
        _rolesModalOpen = true;
    }

    private void OpenInviteToChannel()
    {
        CloseMenu();
        _inviteToChannelOpen = true;
    }

    private string DisplayLabel => !string.IsNullOrWhiteSpace(UserName) ? UserName! :
                                   !string.IsNullOrWhiteSpace(UserUsername) ? UserUsername! : "user";
}

@if (IsSelf)
{
    @ChildContent
}
else
{
    <span class="user-menu-anchor @Class"
          @oncontextmenu="OpenMenu"
          @oncontextmenu:preventDefault="true"
          @oncontextmenu:stopPropagation="true">
        @ChildContent

        @if (_open)
        {
            <div class="user-menu-backdrop" @onclick="CloseMenu" @oncontextmenu="CloseMenu" @oncontextmenu:preventDefault="true"></div>
        }
        <Popover Open="_open"
                 Placement="Popover.PopoverPlacement.BottomLeft"
                 OnClose="CloseMenu">
            <ul class="user-menu" @onclick:stopPropagation="true">
                <li><button type="button" class="user-menu-item" @onclick="SendDmAsync">Send direct message</button></li>
                @if (!_isFriend)
                {
                    <li><button type="button" class="user-menu-item" @onclick="SendFriendRequestAsync">Send friend request</button></li>
                }
                <li><button type="button" class="user-menu-item" @onclick="OpenInviteToChannel">Invite to a channel…</button></li>
                <li><button type="button" class="user-menu-item" @onclick="Report">Report</button></li>
                <li><button type="button" class="user-menu-item danger" @onclick="BlockAsync">Block</button></li>

                @if (InChannel && !IsTargetOwner && (CanManageRoles || CanMute || CanKick || CanBan))
                {
                    <li class="user-menu-sep" role="separator"></li>
                }
                @if (CanManageRoles && !IsTargetOwner)
                {
                    <li><button type="button" class="user-menu-item" @onclick="OpenManageRoles">Manage roles</button></li>
                }
                @if (CanMute && !IsTargetOwner)
                {
                    <li><button type="button" class="user-menu-item" @onclick="@(() => OpenModeration(ModerationActionType.Mute))">Mute</button></li>
                }
                @if (CanKick && !IsTargetOwner)
                {
                    <li><button type="button" class="user-menu-item danger" @onclick="KickAsync">Kick</button></li>
                }
                @if (CanBan && !IsTargetOwner)
                {
                    <li><button type="button" class="user-menu-item danger" @onclick="@(() => OpenModeration(ModerationActionType.Ban))">Ban</button></li>
                }
            </ul>
        </Popover>
    </span>

    <ModerationActionModal Open="_moderationModalOpen"
                           ChannelId="@(ChannelId ?? Guid.Empty)"
                           TargetUserId="@(_moderationModalOpen ? UserId : (Guid?)null)"
                           OnClose="@(() => _moderationModalOpen = false)" />

    <ManageRolesModal Open="_rolesModalOpen"
                      ChannelId="@(ChannelId ?? Guid.Empty)"
                      TargetUserId="@UserId"
                      TargetName="@DisplayLabel"
                      OnClose="@(() => _rolesModalOpen = false)" />

    <InviteToChannelModal Open="_inviteToChannelOpen"
                          TargetUserId="@UserId"
                          TargetName="@DisplayLabel"
                          TargetUsername="@UserUsername"
                          OnClose="@(() => _inviteToChannelOpen = false)" />

    <ReportModal Open="@_reportModalOpen"
                 OpenChanged="@((v) => _reportModalOpen = v)"
                 TargetKind="User"
                 TargetId="@UserId" />
}
