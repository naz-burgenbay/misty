@inject IUserDirectory Users

@code {
    [Parameter] public string Placeholder { get; set; } = "Write a message…";
    [Parameter] public MockMessage? ReplyingTo { get; set; }
    [Parameter] public EventCallback OnClearReply { get; set; }
    [Parameter] public EventCallback<string> OnSend { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private string _draft = string.Empty;

    private string ReplyAuthorName
    {
        get
        {
            if (ReplyingTo is null) return string.Empty;
            _ = Users.EnsureAsync(ReplyingTo.AuthorId);
            return Users.Get(ReplyingTo.AuthorId).DisplayName;
        }
    }

    private string ReplyPreviewText =>
        ReplyingTo is null ? string.Empty
        : ReplyingTo.IsTombstone ? "[message deleted]"
        : ReplyingTo.Content;

    private async Task Send()
    {
        if (Disabled) return;
        var text = _draft.Trim();
        if (text.Length == 0) return;
        await OnSend.InvokeAsync(text);
        _draft = string.Empty;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }
}

<div class="composer @(Disabled ? "disabled" : "")">
    @if (ReplyingTo is not null)
    {
        <div class="reply-chip">
            <span class="reply-icon"><Blazicon Svg="Lucide.CornerUpLeft" /></span>
            <span class="reply-author">Replying to @ReplyAuthorName</span>
            <span class="reply-preview">@ReplyPreviewText</span>
            <IconButton Title="Cancel reply" OnClick="OnClearReply"><Blazicon Svg="Lucide.X" /></IconButton>
        </div>
    }

    <div class="row">
        <IconButton Title="Attach"><Blazicon Svg="Lucide.Paperclip" /></IconButton>
        <textarea class="input"
                  rows="1"
                  placeholder="@Placeholder"
                  disabled="@Disabled"
                  @bind="_draft"
                  @bind:event="oninput"
                  @onkeydown="OnKeyDown"></textarea>
        <IconButton Title="Emoji"><Blazicon Svg="Lucide.Smile" /></IconButton>
        <Button Variant="Button.ButtonVariant.Primary" OnClick="Send" Disabled="@(Disabled || string.IsNullOrWhiteSpace(_draft))">
            <Blazicon Svg="Lucide.Send" />
            <span>Send</span>
        </Button>
    </div>
</div>
