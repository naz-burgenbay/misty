@using Microsoft.AspNetCore.Components.Forms
@inject IUserDirectory Users

@code {
    public sealed record MessageComposerSubmit(string Content, IBrowserFile? Attachment);

    [Parameter] public string Placeholder { get; set; } = "Write a message…";
    [Parameter] public MockMessage? ReplyingTo { get; set; }
    [Parameter] public EventCallback OnClearReply { get; set; }
    [Parameter] public EventCallback<MessageComposerSubmit> OnSend { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool AttachmentsEnabled { get; set; } = true;

    private string _draft = string.Empty;
    private IBrowserFile? _pendingAttachment;

    private string ReplyAuthorName
    {
        get
        {
            if (ReplyingTo is null) return string.Empty;
            _ = Users.EnsureAsync(ReplyingTo.AuthorId);
            return Users.Get(ReplyingTo.AuthorId).DisplayName;
        }
    }

    private string ReplyPreviewText =>
        ReplyingTo is null ? string.Empty
        : ReplyingTo.IsTombstone ? "[message deleted]"
        : ReplyingTo.Content;

    private bool CanSubmit => !Disabled && (!string.IsNullOrWhiteSpace(_draft) || _pendingAttachment is not null);

    private async Task Send()
    {
        if (!CanSubmit) return;
        var text = _draft.Trim();
        var attachment = _pendingAttachment;
        _draft = string.Empty;
        _pendingAttachment = null;
        await OnSend.InvokeAsync(new MessageComposerSubmit(text, attachment));
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _pendingAttachment = e.File;
    }

    private void ClearAttachment() => _pendingAttachment = null;

    private bool _emojiOpen;

    private static readonly string[] CommonEmojis =
    [
        "😀","😂","😍","🥰","😎","🤔","😅","🙏",
        "👍","👎","❤️","🔥","✨","🎉","💯","🤣",
        "😢","😭","😤","😡","👀","🤝","💪","🙌",
        "😊","😏","🫡","🤩","😬","😴","🤗","😇",
    ];

    private void InsertEmoji(string emoji)
    {
        _draft += emoji;
        _emojiOpen = false;
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:0.#} KB",
        _ => $"{bytes / (1024.0 * 1024.0):0.#} MB",
    };
}

<div class="composer @(Disabled ? "disabled" : "")">
    @if (ReplyingTo is not null)
    {
        <div class="reply-chip">
            <span class="reply-icon"><Blazicon Svg="Lucide.CornerUpLeft" /></span>
            <span class="reply-author">Replying to @ReplyAuthorName</span>
            <span class="reply-preview">@ReplyPreviewText</span>
            <IconButton Title="Cancel reply" OnClick="OnClearReply"><Blazicon Svg="Lucide.X" /></IconButton>
        </div>
    }

    @if (_pendingAttachment is not null)
    {
        <div class="attachment-chip">
            <Blazicon Svg="Lucide.Paperclip" />
            <span class="name">@_pendingAttachment.Name</span>
            <span class="size">@FormatSize(_pendingAttachment.Size)</span>
            <IconButton Title="Remove attachment" OnClick="ClearAttachment"><Blazicon Svg="Lucide.X" /></IconButton>
        </div>
    }

    <div class="row">
        @if (AttachmentsEnabled)
        {
            <label class="attach-btn" title="Attach file">
                <Blazicon Svg="Lucide.Paperclip" />
                <InputFile OnChange="OnFileSelected" style="display:none" />
            </label>
        }
        <textarea class="input"
                  rows="1"
                  placeholder="@Placeholder"
                  disabled="@Disabled"
                  @bind="_draft"
                  @bind:event="oninput"
                  @onkeydown="OnKeyDown"></textarea>
        <IconButton Title="Emoji" OnClick="@(() => _emojiOpen = !_emojiOpen)"><Blazicon Svg="Lucide.Smile" /></IconButton>
        @if (_emojiOpen)
        {
            <div class="emoji-backdrop" @onclick="@(() => _emojiOpen = false)"></div>
            <div class="emoji-picker">
                @foreach (var emoji in CommonEmojis)
                {
                    var e = emoji;
                    <button type="button" class="emoji-btn" @onclick="@(() => InsertEmoji(e))">@e</button>
                }
            </div>
        }
        <Button Variant="Button.ButtonVariant.Primary" OnClick="Send" Disabled="@(!CanSubmit)">
            <Blazicon Svg="Lucide.Send" />
            <span>Send</span>
        </Button>
    </div>
</div>

