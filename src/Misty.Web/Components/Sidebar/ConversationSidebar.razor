@inject NavigationManager Nav
@inject IChannelService Channels
@inject IDirectMessageService DirectMessages
@inject IUserDirectory Users
@inject IToastService Toasts
@implements IDisposable

<aside class="sidebar">
    <header class="head">
        <h1 class="title">Misty</h1>
        <IconButton Title="New conversation"><Blazicon Svg="Lucide.SquarePen" /></IconButton>
    </header>

    <div class="search">
        <TextField Value="@_search" ValueChanged="@(v => _search = v ?? string.Empty)"
                   Placeholder="Search conversations" />
    </div>

    <div class="scroll">
        <section class="group">
            <div class="group-head">
                <span class="label">Channels</span>
                <IconButton Title="New channel" OnClick="@(() => _createOpen = true)"><Blazicon Svg="Lucide.Plus" /></IconButton>
            </div>
            @foreach (var channel in FilteredChannels)
            {
                <ChannelListItem Channel="channel"
                                 Selected="@IsChannelActive(channel.Id)"
                                 Href="@($"/c/{channel.Id}")" />
            }
            @if (_channels.Count == 0)
            {
                <div class="empty-hint">No channels yet. Create one.</div>
            }
        </section>

        <section class="group">
            <div class="group-head">
                <span class="label">Direct messages</span>
                <IconButton Title="New DM" OnClick="@(() => _newDmOpen = true)"><Blazicon Svg="Lucide.Plus" /></IconButton>
            </div>
            @foreach (var dm in FilteredDirects)
            {
                <DirectMessageListItem Conversation="dm"
                                       Selected="@IsDmActive(dm.Id)"
                                       Href="@($"/dm/{dm.Id}")" />
            }
            @if (_directs.Count == 0)
            {
                <div class="empty-hint">No direct messages yet.</div>
            }
        </section>
    </div>
</aside>

@if (_createOpen)
{
    <Modal Open="true" Title="Create a channel" OnClose="CloseCreate">
        <ChildContent>
            <div class="create-form profile-style">
                <div class="profile-head">
                    <div class="icon-placeholder">
                        <Blazicon Svg="Lucide.Hash" />
                    </div>
                    <div class="profile-hint">Your channel will be set up in seconds.</div>
                </div>

                <div class="field">
                    <span class="lbl">Channel name <span class="required">*</span></span>
                    <TextField Value="@_newName" ValueChanged="@(v => _newName = v ?? string.Empty)"
                               Placeholder="e.g. backend" />
                </div>
                <div class="field">
                    <span class="lbl">Description</span>
                    <TextField Value="@_newDescription" ValueChanged="@(v => _newDescription = v ?? string.Empty)"
                               Placeholder="What's this channel about?" />
                </div>

                <div class="form-row">
                    <div class="field">
                        <span class="lbl">Privacy</span>
                        <SegmentedControl Options="@(new [] { "Public", "Private" })"
                                          Value="@(_newPrivate ? "Private" : "Public")"
                                          ValueChanged="@(v => _newPrivate = v == "Private")" />
                    </div>
                    <div class="field">
                        <span class="lbl">AI assistant</span>
                        <SegmentedControl Options="@(new [] { "Off", "On" })"
                                          Value="@(_newAi ? "On" : "Off")"
                                          ValueChanged="@(v => _newAi = v == "On")" />
                    </div>
                </div>

                <div class="field">
                    <span class="lbl">Invite friends</span>
                    <TextField Value="@_inviteQuery"
                               ValueChanged="OnInviteQueryChanged"
                               Placeholder="Search by username or display name" />
                    @if (_inviteSearching)
                    {
                        <div class="hint">Searching…</div>
                    }
                    else if (_inviteResults.Count > 0)
                    {
                        <div class="user-results">
                            @foreach (var user in _inviteResults)
                            {
                                var u = user;
                                <button type="button" class="user-result @(_invitedUsers.Contains(u.Id) ? "selected" : "")"
                                        @onclick="@(() => ToggleInvite(u))">
                                    <Avatar Name="@u.DisplayName" ImageUrl="@u.AvatarUrl" Size="Avatar.AvatarSize.Small" />
                                    <span class="user-result-text">
                                        <span class="display-name">@u.DisplayName</span>
                                        <span class="username">@@@u.Username</span>
                                    </span>
                                    @if (_invitedUsers.Contains(u.Id))
                                    {
                                        <Blazicon Svg="Lucide.Check" />
                                    }
                                </button>
                            }
                        </div>
                    }
                    @if (_invitedUsers.Count > 0)
                    {
                        <div class="invited-chips">
                            @foreach (var u in _invitedUserDetails)
                            {
                                var uid = u.Id;
                                <span class="chip">
                                    @u.DisplayName
                                    <button type="button" @onclick="@(() => _invitedUsers.Remove(uid))" class="chip-remove">
                                        <Blazicon Svg="Lucide.X" />
                                    </button>
                                </span>
                            }
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_createError))
                {
                    <div class="form-error">@_createError</div>
                }
            </div>
        </ChildContent>
        <Footer>
            <Button Variant="Button.ButtonVariant.Ghost" OnClick="CloseCreate">Cancel</Button>
            <Button Variant="Button.ButtonVariant.Primary"
                    Disabled="@(_creating || string.IsNullOrWhiteSpace(_newName))"
                    OnClick="CreateAsync">@(_creating ? "Creating…" : "Create channel")</Button>
        </Footer>
    </Modal>
}

@if (_newDmOpen)
{
    <Modal Open="true" Title="Start a direct message" OnClose="@CloseNewDm">
        <ChildContent>
            <div class="create-form">
                <div class="field">
                    <span class="lbl">Find a user</span>
                    <TextField Value="@_newDmQuery"
                               ValueChanged="@OnDmQueryChanged"
                               Placeholder="Search by username or display name" />
                </div>
                @if (_searchingDm)
                {
                    <div class="hint">Searching…</div>
                }
                else if (_dmResults.Count == 0 && !string.IsNullOrWhiteSpace(_newDmQuery))
                {
                    <div class="hint">No users found.</div>
                }
                else if (_dmResults.Count > 0)
                {
                    <div class="user-results">
                        @foreach (var user in _dmResults)
                        {
                            <button type="button" class="user-result" @onclick="@(() => StartDmAsync(user.Id))" disabled="@_creatingDm">
                                <UserContextMenu UserId="@user.Id" UserName="@user.DisplayName" UserUsername="@user.Username">
                                    <Avatar Name="@user.DisplayName" ImageUrl="@user.AvatarUrl" Size="Avatar.AvatarSize.Small" />
                                </UserContextMenu>
                                <span class="user-result-text">
                                    <span class="display-name">@user.DisplayName</span>
                                    <span class="username">@@@user.Username</span>
                                </span>
                            </button>
                        }
                    </div>
                }
                @if (!string.IsNullOrEmpty(_newDmError))
                {
                    <div class="form-error">@_newDmError</div>
                }
            </div>
        </ChildContent>
        <Footer>
            <Button Variant="Button.ButtonVariant.Ghost" OnClick="CloseNewDm">Cancel</Button>
        </Footer>
    </Modal>
}

@code {
    private string _search = string.Empty;
    private IReadOnlyList<ChannelSummaryDto> _channels = Array.Empty<ChannelSummaryDto>();
    private IReadOnlyList<DirectConversationDto> _directs = Array.Empty<DirectConversationDto>();
    private IDisposable? _channelsSub;
    private IDisposable? _directsSub;

    private bool _createOpen;
    private bool _creating;
    private string _newName = string.Empty;
    private string _newDescription = string.Empty;
    private bool _newPrivate;
    private bool _newAi;
    private string? _createError;

    private string _inviteQuery = string.Empty;
    private bool _inviteSearching;
    private IReadOnlyList<UserSummaryWithAvatar> _inviteResults = Array.Empty<UserSummaryWithAvatar>();
    private HashSet<Guid> _invitedUsers = new();
    private List<UserSummaryWithAvatar> _invitedUserDetails = new();
    private CancellationTokenSource? _inviteSearchCts;

    private bool _newDmOpen;
    private bool _creatingDm;
    private string _newDmQuery = string.Empty;
    private IReadOnlyList<UserSummaryWithAvatar> _dmResults = Array.Empty<UserSummaryWithAvatar>();
    private bool _searchingDm;
    private CancellationTokenSource? _dmSearchCts;
    private string? _newDmError;

    private IEnumerable<ChannelSummaryDto> FilteredChannels =>
        string.IsNullOrWhiteSpace(_search)
            ? _channels
            : _channels.Where(c => c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<DirectConversationDto> FilteredDirects => _directs;

    private string CurrentPath => "/" + Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
    private bool IsChannelActive(Guid id) => CurrentPath.Equals($"/c/{id}", StringComparison.OrdinalIgnoreCase);
    private bool IsDmActive(Guid id) => CurrentPath.Equals($"/dm/{id}", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocation;
        _channelsSub = Channels.MyChannels.Subscribe(list =>
        {
            _channels = list;
            InvokeAsync(StateHasChanged);
        });
        _directsSub = DirectMessages.MyConversations.Subscribe(list =>
        {
            _directs = list;
            InvokeAsync(StateHasChanged);
        });
        _ = Channels.RefreshAsync();
        _ = DirectMessages.RefreshAsync();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocation;
        _channelsSub?.Dispose();
        _directsSub?.Dispose();
        _dmSearchCts?.Cancel();
        _dmSearchCts?.Dispose();
        _inviteSearchCts?.Cancel();
        _inviteSearchCts?.Dispose();
    }

    private void OnLocation(object? _, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs __) => StateHasChanged();

    private void CloseCreate()
    {
        _createOpen = false;
        _createError = null;
        _newName = string.Empty;
        _newDescription = string.Empty;
        _newPrivate = false;
        _newAi = false;
        _inviteQuery = string.Empty;
        _inviteResults = Array.Empty<UserSummaryWithAvatar>();
        _invitedUsers = new();
        _invitedUserDetails = new();
        _inviteSearchCts?.Cancel();
        _inviteSearchCts = null;
    }

    private async Task OnInviteQueryChanged(string? value)
    {
        _inviteQuery = value ?? string.Empty;
        _inviteSearchCts?.Cancel();
        if (string.IsNullOrWhiteSpace(_inviteQuery))
        {
            _inviteResults = Array.Empty<UserSummaryWithAvatar>();
            _inviteSearching = false;
            return;
        }
        var cts = new CancellationTokenSource();
        _inviteSearchCts = cts;
        _inviteSearching = true;
        try
        {
            await Task.Delay(200, cts.Token);
            var results = await Users.SearchAsync(_inviteQuery, take: 10, cts.Token);
            if (!cts.IsCancellationRequested)
                _inviteResults = results;
        }
        catch (TaskCanceledException) { }
        finally
        {
            if (!cts.IsCancellationRequested)
                _inviteSearching = false;
        }
    }

    private void ToggleInvite(UserSummaryWithAvatar user)
    {
        if (_invitedUsers.Contains(user.Id))
        {
            _invitedUsers.Remove(user.Id);
            _invitedUserDetails.RemoveAll(u => u.Id == user.Id);
        }
        else
        {
            _invitedUsers.Add(user.Id);
            _invitedUserDetails.Add(user);
        }
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newName)) return;
        _creating = true;
        _createError = null;
        try
        {
            var created = await Channels.CreateAsync(_newName.Trim(), _newPrivate, _newAi);
            foreach (var u in _invitedUserDetails)
            {
                try { await Channels.SendInviteAsync(created.Id, u.Username); } catch { }
            }
            CloseCreate();
            Toasts.Show($"Created #{created.Name}.", ToastKind.Success);
            Nav.NavigateTo($"/c/{created.Id}");
        }
        catch (Exception ex)
        {
            _createError = ex.Message;
        }
        finally
        {
            _creating = false;
        }
    }

    private void CloseNewDm()
    {
        _dmSearchCts?.Cancel();
        _dmSearchCts = null;
        _newDmOpen = false;
        _newDmError = null;
        _newDmQuery = string.Empty;
        _dmResults = Array.Empty<UserSummaryWithAvatar>();
        _searchingDm = false;
    }

    private async Task OnDmQueryChanged(string? value)
    {
        _newDmQuery = value ?? string.Empty;
        _newDmError = null;

        _dmSearchCts?.Cancel();
        if (string.IsNullOrWhiteSpace(_newDmQuery))
        {
            _dmResults = Array.Empty<UserSummaryWithAvatar>();
            _searchingDm = false;
            return;
        }

        var cts = new CancellationTokenSource();
        _dmSearchCts = cts;
        _searchingDm = true;
        try
        {
            await Task.Delay(200, cts.Token);
            var results = await Users.SearchAsync(_newDmQuery, take: 10, cts.Token);
            if (cts.IsCancellationRequested) return;
            _dmResults = results;
        }
        catch (TaskCanceledException) { }
        finally
        {
            if (!cts.IsCancellationRequested)
                _searchingDm = false;
        }
    }

    private async Task StartDmAsync(Guid otherId)
    {
        if (_creatingDm) return;
        _newDmError = null;
        _creatingDm = true;
        try
        {
            var created = await DirectMessages.CreateOrGetAsync(otherId);
            CloseNewDm();
            Nav.NavigateTo($"/dm/{created.Id}");
        }
        catch (Exception ex)
        {
            _newDmError = ex.Message;
        }
        finally
        {
            _creatingDm = false;
        }
    }
}
