@code {
    [Parameter, EditorRequired] public ChannelSummaryDto Channel { get; set; } = default!;
    [Parameter] public bool Selected { get; set; }
    [Parameter] public bool HasUnread { get; set; }
    [Parameter] public string Href { get; set; } = "#";
}

<a class="row @(Selected ? "selected" : "")" href="@Href">
    <span class="icon">
        @if (Channel.IsPrivate)
        {
            <Blazicon Svg="Lucide.Lock" />
        }
        else
        {
            <Blazicon Svg="Lucide.Hash" />
        }
    </span>
    <span class="name">@Channel.Name</span>
    @if (HasUnread)
    {
        <span class="unread-dot" aria-label="Unread messages"></span>
    }
</a>
